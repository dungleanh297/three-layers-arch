@namespace HotelReservation.Web
@inject ICustomerService CustomerService
@page "/customers"

<PageTitle>Customer Management</PageTitle>

<h1>Customer Management</h1>

@if (customers == null)
{
    <p><em>Loading...</em></p>
    return;
}

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="bi bi-plus-circle"></i> Add New Customer
    </button>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Search Customers</h5>
        <EditForm Model="searchCriteria" OnValidSubmit="SearchCustomers">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="searchCriteria.Name" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="searchCriteria.Email" />
                    <ValidationMessage For="() => searchCriteria.Email" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Phone Number</label>
                    <InputText class="form-control" @bind-Value="searchCriteria.PhoneNumber" />
                    <ValidationMessage For="() => searchCriteria.PhoneNumber" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Society Card Number</label>
                    <InputText class="form-control" @bind-Value="searchCriteria.SocietyCardNumber" />
                    <ValidationMessage For="() => searchCriteria.SocietyCardNumber" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-secondary me-2">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearSearch">
                        Clear
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (customers.Count == 0)
{
    <div class="alert alert-info">No customers found. Click "Add New Customer" to create one.</div>
}
else
{
    <QuickGrid Items="customers.AsQueryable()" class="table table-striped table-hover">
        <PropertyColumn Property="c => c.Id" Title="ID" />
        <PropertyColumn Property="c => c.Name" Title="Name" />
        <PropertyColumn Property="c => c.Email" Title="Email" />
        <PropertyColumn Property="c => c.PhoneNumber" Title="Phone Number" />
        <PropertyColumn Property="c => c.SocietyCardNumber" Title="Society Card Number" />
        <TemplateColumn Title="Actions">
            <button class="btn btn-sm btn-warning me-2" @onclick="() => ShowEditModal(context)">
                Edit
            </button>
            <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(context)">
                Delete
            </button>
        </TemplateColumn>
    </QuickGrid>
}

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditing ? "Edit Customer" : "Add New Customer")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm EditContext="editContext" OnValidSubmit="SaveCustomer">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="currentCustomer.Name" />
                            <ValidationMessage For="() => currentCustomer.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="currentCustomer.Email" />
                            <ValidationMessage For="() => currentCustomer.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="currentCustomer.PhoneNumber" />
                            <ValidationMessage For="() => currentCustomer.PhoneNumber" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Society Card Number</label>
                            <InputText class="form-control" @bind-Value="currentCustomer.SocietyCardNumber" />
                            <ValidationMessage For="() => currentCustomer.SocietyCardNumber" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            @(isEditing ? "Update" : "Create")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteConfirmation"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete customer <strong>@customerToDelete?.Name</strong>?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteConfirmation">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteCustomer">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3">@successMessage</div>
}

@code {
    private List<CustomerDTO>? customers;
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private bool isEditing = false;
    private CustomerDTO? customerToDelete;
    private PutCustomerRequest currentCustomer = new();
    private string? errorMessage;
    private string? successMessage;
    private int editingCustomerId = 0;
    private CustomerSearchCriteria searchCriteria = new();
    private EditContext? editContext;
    private BusinessExceptionPopulator? exceptionPopulator;

    protected override Task OnInitializedAsync()
    {
        return LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        customers = await CustomerService.GetAsync(searchCriteria);
        errorMessage = null;
    }

    private Task SearchCustomers()
    {
        return LoadCustomers();
    }

    private Task ClearSearch()
    {
        searchCriteria = new CustomerSearchCriteria();
        return LoadCustomers();
    }

    private void ShowCreateModal()
    {
        currentCustomer = new PutCustomerRequest();
        editContext = new EditContext(currentCustomer);
        exceptionPopulator = new BusinessExceptionPopulator(editContext);
        isEditing = false;
        errorMessage = null;
        successMessage = null;
        showModal = true;
    }

    private void ShowEditModal(CustomerDTO customer)
    {
        currentCustomer = new PutCustomerRequest
        {
            Name = customer.Name,
            Email = customer.Email,
            PhoneNumber = customer.PhoneNumber,
            SocietyCardNumber = customer.SocietyCardNumber
        };

        editContext = new EditContext(currentCustomer);
        exceptionPopulator = new BusinessExceptionPopulator(editContext);
        editingCustomerId = customer.Id;
        isEditing = true;
        errorMessage = null;
        successMessage = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentCustomer = new PutCustomerRequest();
    }

    private async Task SaveCustomer()
    {
        try
        {
            if (isEditing)
            {
                await CustomerService.UpdateAsync(editingCustomerId, currentCustomer);
                successMessage = "Customer updated successfully!";
            }
            else
            {
                await CustomerService.CreateAsync(currentCustomer);
                successMessage = "Customer created successfully!";
            }
            CloseModal();
            await LoadCustomers();
        }
        catch (BusinessException ex)
        {
            exceptionPopulator?.PopulateExceptionMessage(ex);
            errorMessage = null;
            successMessage = null;
        }
    }

    private void ShowDeleteConfirmation(CustomerDTO customer)
    {
        customerToDelete = customer;
        showDeleteConfirm = true;
    }

    private void CloseDeleteConfirmation()
    {
        showDeleteConfirm = false;
        customerToDelete = null;
    }

    private async Task DeleteCustomer()
    {
        if (customerToDelete == null) return;

        await CustomerService.DeleteAsync(customerToDelete.Id);
        successMessage = "Customer deleted successfully!";
        CloseDeleteConfirmation();
        await LoadCustomers();
    }
}

