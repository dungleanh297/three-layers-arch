@namespace HotelReservation.Web
@page "/rooms"
@inject IRoomService RoomService

<PageTitle>Room Management</PageTitle>

<h1>Room Management</h1>

@if (rooms == null)
{
    <p><em>Loading...</em></p>
    return;
}

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="bi bi-plus-circle"></i> Add New Room
    </button>
</div>

@if (rooms.Count == 0)
{
    <div class="alert alert-info">No rooms found. Click "Add New Room" to create one.</div>
}
else
{
    <QuickGrid Items="rooms.AsQueryable()" class="table table-striped table-hover">
        <PropertyColumn Property="r => r.Id" Title="ID" />
        <PropertyColumn Property="r => r.RoomNumber" Title="Room Number" />
        <PropertyColumn Property="r => r.Floor" Title="Floor" />
        <PropertyColumn Property="r => r.Price" Title="Price" Format="C" />
        <TemplateColumn Title="Status">
            @if (context.HasBeenTaken)
            {
                <span class="badge bg-danger">Occupied</span>
            }
            else
            {
                <span class="badge bg-success">Available</span>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <button class="btn btn-sm btn-warning me-2" @onclick="() => ShowEditModal(context)">
                Edit
            </button>
            <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(context)">
                Delete
            </button>
        </TemplateColumn>
    </QuickGrid>
}

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditing ? "Edit Room" : "Add New Room")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="currentRoom" EditContext="editContext" OnValidSubmit="SaveRoom">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Room Number</label>
                            <InputNumber class="form-control" @bind-Value="currentRoom.RoomNumber" />
                            <ValidationMessage For="() => currentRoom.RoomNumber" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Floor</label>
                            <InputNumber class="form-control" @bind-Value="currentRoom.Floor" />
                            <ValidationMessage For="() => currentRoom.Floor" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Price</label>
                            <InputNumber class="form-control" @bind-Value="currentRoom.Price" step="0.01" />
                            <ValidationMessage For="() => currentRoom.Price" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            @(isEditing ? "Update" : "Create")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteConfirmation"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete room <strong>@roomToDelete?.RoomNumber</strong>?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteConfirmation">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteRoom">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3">@successMessage</div>
}

@code {
    private List<RoomDTO>? rooms;
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private bool isEditing = false;
    private RoomDTO? roomToDelete;
    private PutRoomInformation currentRoom = new();
    private string? errorMessage;
    private string? successMessage;
    private int editingRoomId = 0;
    private EditContext? editContext;
    private BusinessExceptionPopulator? exceptionPopulator;

    protected override async Task OnInitializedAsync()
    {
        await LoadRooms();
    }

    private async Task LoadRooms()
    {
        rooms = await RoomService.GetAsync();
        errorMessage = null;
    }

    private void ShowCreateModal()
    {
        currentRoom = new PutRoomInformation();
        editContext = new EditContext(currentRoom);
        exceptionPopulator = new BusinessExceptionPopulator(editContext);
        isEditing = false;
        errorMessage = null;
        successMessage = null;
        showModal = true;
    }

    private void ShowEditModal(RoomDTO room)
    {
        currentRoom = new PutRoomInformation
        {
            RoomNumber = room.RoomNumber,
            Floor = room.Floor,
            Price = room.Price
        };
        editContext = new EditContext(currentRoom);
        exceptionPopulator = new BusinessExceptionPopulator(editContext);
        editingRoomId = room.Id;
        isEditing = true;
        errorMessage = null;
        successMessage = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentRoom = new PutRoomInformation();
    }

    private void ShowDeleteConfirmation(RoomDTO room)
    {
        roomToDelete = room;
        showDeleteConfirm = true;
        errorMessage = null;
        successMessage = null;
    }

    private void CloseDeleteConfirmation()
    {
        showDeleteConfirm = false;
        roomToDelete = null;
    }

    private async Task SaveRoom()
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (isEditing)
            {
                await RoomService.UpdateAsync(editingRoomId, currentRoom);
                successMessage = "Room updated successfully!";
            }
            else
            {
                await RoomService.CreateAsync(currentRoom);
                successMessage = "Room created successfully!";
            }

            await LoadRooms();
            CloseModal();
        }
        catch (BusinessException ex)
        {
            exceptionPopulator?.PopulateExceptionMessage(ex);
            errorMessage = null;
        }
    }

    private async Task DeleteRoom()
    {
        if (roomToDelete == null) return;

        errorMessage = null;
        successMessage = null;
        await RoomService.DeleteAsync(roomToDelete.Id);
        successMessage = "Room deleted successfully!";
        await LoadRooms();
        CloseDeleteConfirmation();
    }
}